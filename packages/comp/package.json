{
  "name": "jsh-comp",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./type": {
      "import": "./dist/type/index.mjs",
      "require": "./dist/type/index.js",
      "types": "./dist/type/index.d.ts"
    },
    "./type/*": {
      "import": "./dist/type/*.mjs",
      "require": "./dist/type/*.js",
      "types": "./dist/type/*.d.ts"
    },
    "./doc": "./src/doc/index.ts",
    "./doc/style/*": "./src/doc/style/*",
    "./style.css": "./dist/style.css"
  },
  "sideEffects": ["**/*.css", "**/*.scss"],
  "scripts": {
    "build": "vue-tsc -b && vite build --config vite.lib.config.ts",
    "typecheck": "vue-tsc -b --noEmit"
  },
  "dependencies": {
    "jsh-core": "workspace:*",
    "jsh-tool": "workspace:*"
  },
  "peerDependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "canvaskit-wasm": "^0.41.0",
    "element-plus": "^2.8.0",
    "lodash-es": "^4.17.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "canvaskit-wasm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@fontsource/noto-sans-sc": "5.2.5",
    "@types/lodash-es": "^4.17.12",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/tsconfig": "^0.7.0",
    "canvaskit-wasm": "^0.41.1",
    "element-plus": "^2.8.8",
    "lodash-es": "^4.18.1",
    "sass": "^1.81.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}

{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "../../node_modules/.tmp/tsconfig.playground.tsbuildinfo",
    "strict": true,
    "noEmit": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../comp/src/*"],
      "jsh-comp": ["../comp/src/index.ts"],
      "jsh-comp/doc": ["../comp/src/doc/index.ts"],
      "jsh-comp/doc/style/*": ["../comp/src/doc/style/*"],
      "jsh-comp/type": ["../comp/src/type/index.ts"],
      "jsh-comp/type/*": ["../comp/src/type/*"],
      "jsh-tool": ["../tool/src/index.ts"],
      "jsh-tool/doc": ["../tool/src/doc/index.ts"],
      "jsh-tool/*": ["../tool/src/*"],
      "jsh-core": ["../core/src/index.ts"],
      "jsh-core/doc": ["../core/src/doc/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.vue", "env.d.ts"]
}

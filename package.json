{
  "name": "comp-vue-lib",
  "version": "0.8.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./util": {
      "import": "./dist/util/index.mjs",
      "require": "./dist/util/index.js",
      "types": "./dist/util/index.d.ts"
    },
    "./util/*": {
      "import": "./dist/util/*.mjs",
      "require": "./dist/util/*.js",
      "types": "./dist/util/*.d.ts"
    },
    "./type": {
      "import": "./dist/type/index.mjs",
      "require": "./dist/type/index.js",
      "types": "./dist/type/index.d.ts"
    },
    "./type/*": {
      "import": "./dist/type/*.mjs",
      "require": "./dist/type/*.js",
      "types": "./dist/type/*.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build --config vite.lib.config.ts",
    "build:playground": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint \"**/*.{css,scss,vue}\"",
    "lint:style:fix": "stylelint \"**/*.{css,scss,vue}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "canvaskit-wasm": "^0.41.0",
    "element-plus": "^2.8.0",
    "lodash-es": "^4.17.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "canvaskit-wasm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@eslint/js": "^9.15.0",
    "@fontsource/noto-sans-sc": "5.2.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.9.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/tsconfig": "^0.7.0",
    "canvaskit-wasm": "^0.41.1",
    "element-plus": "^2.8.8",
    "eslint": "^9.15.0",
    "eslint-plugin-vue": "^9.31.0",
    "highlight.js": "^11.11.1",
    "lodash-es": "^4.18.1",
    "postcss-html": "^1.7.0",
    "prettier": "^3.3.3",
    "sass": "^1.81.0",
    "stylelint": "^17.7.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  },
  "dependencies": {
    "cursor-feedback": "^1.1.0"
  }
}

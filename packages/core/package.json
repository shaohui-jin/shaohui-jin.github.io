{
  "name": "jsh-core",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "files": ["dist", "src/style"],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./doc": {
      "import": "./dist/doc/index.mjs",
      "require": "./dist/doc/index.js",
      "types": "./dist/doc/index.d.ts"
    },
    "./style/variables.scss": "./src/style/variables.scss",
    "./style/*": "./src/style/*"
  },
  "sideEffects": ["**/*.css", "**/*.scss", "**/*.vue"],
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b --noEmit"
  },
  "peerDependencies": {
    "element-plus": "^2.8.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/tsconfig": "^0.7.0",
    "element-plus": "^2.8.8",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}

{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "jsh-core": ["../core/src/index.ts"],
      "jsh-core/*": ["../core/src/*"],
      "jsh-comp/doc": ["../comp/src/doc/index.ts"],
      "jsh-comp/doc/style/*": ["../comp/src/doc/style/*"]
    }
  },
  "include": ["src/**/*.ts", "env.d.ts"]
}

{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "jsh-comp": ["src/index.ts"],
      "jsh-comp/type": ["src/type/index.ts"],
      "jsh-comp/type/*": ["src/type/*"],
      "jsh-comp/doc": ["src/doc/index.ts"],
      "jsh-comp/doc/style/*": ["src/doc/style/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue", "env.d.ts"]
}

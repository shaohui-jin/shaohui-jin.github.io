{
  "name": "jsh-rule",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": ["**/*.css", "**/*.scss"],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.lib.json && vite build --config vite.lib.config.ts",
    "typecheck": "vue-tsc -b",
    "typecheck:strict-null": "vue-tsc --noEmit -p tsconfig.strict.json"
  },
  "dependencies": {
    "@antv/x6": "^3.0.0",
    "@vueuse/core": "^9.13.0",
    "dagre": "^0.8.5",
    "element-plus": "^2.8.8",
    "jsh-comp": "workspace:*",
    "jsh-core": "workspace:*",
    "mitt": "^3.0.1",
    "tslib": "^2.8.1",
    "vue": "^3.5.13"
  },
  "peerDependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@monaco-editor/loader": "^1.7.0",
    "element-plus": "^2.8.0",
    "jsh-comp": "workspace:*",
    "jsh-core": "workspace:*",
    "monaco-editor": "^0.54.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@monaco-editor/loader": "^1.7.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/tsconfig": "^0.7.0",
    "monaco-editor": "^0.54.0",
    "sass": "^1.81.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vite-plugin-static-copy": "^3.2.0",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}

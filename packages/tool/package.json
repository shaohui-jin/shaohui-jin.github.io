{
  "name": "jsh-tool",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./color": {
      "import": "./dist/color.mjs",
      "require": "./dist/color.js",
      "types": "./dist/color.d.ts"
    },
    "./number": {
      "import": "./dist/number.mjs",
      "require": "./dist/number.js",
      "types": "./dist/number.d.ts"
    },
    "./object": {
      "import": "./dist/object.mjs",
      "require": "./dist/object.js",
      "types": "./dist/object.d.ts"
    },
    "./array": {
      "import": "./dist/array.mjs",
      "require": "./dist/array.js",
      "types": "./dist/array.d.ts"
    },
    "./clipboard": {
      "import": "./dist/clipboard.mjs",
      "require": "./dist/clipboard.js",
      "types": "./dist/clipboard.d.ts"
    },
    "./debounce": {
      "import": "./dist/debounce.mjs",
      "require": "./dist/debounce.js",
      "types": "./dist/debounce.d.ts"
    },
    "./optimize": {
      "import": "./dist/optimize.mjs",
      "require": "./dist/optimize.js",
      "types": "./dist/optimize.d.ts"
    },
    "./permission": {
      "import": "./dist/permission.mjs",
      "require": "./dist/permission.js",
      "types": "./dist/permission.d.ts"
    },
    "./typescript": {
      "import": "./dist/typescript.mjs",
      "require": "./dist/typescript.js",
      "types": "./dist/typescript.d.ts"
    },
    "./doc": "./src/doc/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vue": "^3.5.13"
  }
}
